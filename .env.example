# Atlas Bybit Demo env template
# Copy values into your local shell or .env (do not commit real keys)

ATLAS_CCXT_MODE=real
ATLAS_AUTO_TRADING_ENABLED=1
ATLAS_AUTO_TRADING_AUTO_ENABLE_WITH_KEYS=1
ATLAS_AUTO_TRADING_MIN_CONFIDENCE=75
ATLAS_AUTO_TRADING_ALLOW_EXECUTE_WITH_CAUTION=1
ATLAS_AUTO_TRADING_MIN_LEVERAGE=1
ATLAS_AUTO_TRADING_MAX_LEVERAGE=20

ATLAS_BYBIT_TESTNET=0
ATLAS_BYBIT_DEMO_TRADING=1
ATLAS_BYBIT_POSITION_MODE=one_way
ATLAS_BYBIT_LOG_HTTP=0
ATLAS_BYBIT_API_KEY=YOUR_BYBIT_API_KEY
ATLAS_BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET

# Optional risk behavior knobs
ATLAS_REJECT_TIGHT_STOPS=1
ATLAS_MIN_STOP_PERCENT=0.0005
